{
  "version": 2,
  "builds": [
    {
      "src": "*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"],
      "headers": {
        "Access-Control-Allow-Origin": "https://mathmagick.com",
        "Access-Control-Allow-Credentials": "true",
        "Access-Control-Allow-Headers": "Content-Type, Authorization"
      }
    }
  ],
  "crons": [
    {
      "path": "/cron/cleanup",
      "schedule": "0 6 * * *"
    },
      {
      "path": "/cron/refresh-fx-rate",
      "schedule": "0 6 * * *"
    }

  ]
}